    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO system_logs (workflow_name, log_level, message, details) VALUES ('03_kalite_kontrol', '{{ $json.risk_level === 'high' ? 'warning' : 'info' }}', 'Karar: {{ $json.decision }} - {{ $json.reason }}', '{{ JSON.stringify($json).replace(/'/g, \"''\") }}');"
      },
      "id": "log-decision",
